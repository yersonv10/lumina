---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import * as LuminaIcons from "@lumina-kit/icons";

export const prerender = true;

const icons = (Object.entries(LuminaIcons) as [string, any][])
  .filter(([, C]) => typeof C === "function")
  .sort((a, b) => a[0].localeCompare(b[0]));

// Split "SackDollar" / "ArrowLeftSquare2" into ["sack","dollar"] / ["arrow","left","square","2"]
// so any word in a multi-word icon name is searchable.
function tokenize(name: string): string[] {
  return name
    .replace(/([a-z])([A-Z])/g, "$1 $2")
    .replace(/([A-Za-z])([0-9])/g, "$1 $2")
    .toLowerCase()
    .split(/\s+/)
    .filter(Boolean);
}

// Synonyms: if an icon's tokens contain a key, its aliases become searchable.
// This is what makes "money" find SackDollar/Wallet/CreditCard, "delete" find
// Trash, "home" find House-y icons, etc.
