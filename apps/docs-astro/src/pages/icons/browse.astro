const iconData = icons.map(([name, Icon]) => {
  const tokens = tokenize(name);
  const extra = new Set<string>();
  for (const t of tokens) for (const s of SYNONYMS[t] ?? []) extra.add(s);
  const keywords = [name.toLowerCase(), ...tokens, ...extra].join(" ");
  return { name, Icon, keywords };
});
---

<BaseLayout
  title="Browse Icons"
  description={`Search ${icons.length}+ free, open-source React SVG icons from Lumina.`}
>
  <SiteHeader />

  <main class="mx-auto max-w-6xl px-6 py-12">
    <header class="max-w-2xl">
      <a href="/icons" class="inline-flex items-center gap-1.5 text-sm text-text-secondary transition hover:text-text-primary">
        <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="m15 18-6-6 6-6"></path>
        </svg>
        Icons docs
      </a>
      <h1 class="font-display mt-3 text-4xl font-medium text-text-primary md:text-5xl">
        Browse all icons
      </h1>
      <p class="mt-4 text-lg text-text-secondary">
        {icons.length} icons. Click any one to copy its import statement.
      </p>
    </header>

    <!-- Search -->
    <div class="sticky top-16 z-30 -mx-6 mt-8 border-y border-border bg-background/90 px-6 py-4 backdrop-blur">
      <div class="flex flex-wrap items-center gap-3">
        <div class="relative flex-1 md:min-w-80">
          <svg class="pointer-events-none absolute top-1/2 left-3 size-4 -translate-y-1/2 text-text-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="7"></circle><path d="m21 21-4.3-4.3"></path>
          </svg>
          <input
            id="icon-search"
            type="search"
            placeholder="Search icons…"
            autocomplete="off"
            class="w-full rounded-(--radius-control) border border-border bg-background-raised py-2 pr-3 pl-9 text-sm text-text-primary outline-none placeholder:text-text-muted focus-visible:ring-2 focus-visible:ring-primary-500"
          />
        </div>
        <p id="icon-count" class="font-mono text-xs text-text-muted">{icons.length} icons</p>
      </div>
    </div>

    <!-- Grid -->
    <ul id="icon-grid" class="mt-6 grid grid-cols-[repeat(auto-fill,minmax(96px,1fr))] gap-2">
      {
        iconData.map(({ name, Icon, keywords }) => (
          <li data-icon data-name={keywords}>
            <button
              type="button"
              data-copy={`import { ${name} } from "@lumina-kit/icons";`}
              title={name}
              class="group flex aspect-square w-full flex-col items-center justify-center gap-2 rounded-(--radius-control) border border-transparent p-2 text-text-secondary transition hover:border-border hover:bg-background-soft hover:text-text-primary"
            >
              <Icon size={26} />
              <span class="w-full truncate text-center text-[10px] leading-tight text-text-muted group-hover:text-text-secondary">
                {name}
              </span>
            </button>
          </li>
        ))
      }
    </ul>

    <p id="icon-empty" class="hidden py-16 text-center text-text-secondary">
      No icons match your search.
    </p>
  </main>

  <!-- Copy toast -->
  <div
    id="copy-toast"
    class="pointer-events-none fixed bottom-6 left-1/2 z-50 -translate-x-1/2 translate-y-2 rounded-(--radius-control) bg-background-inverted px-4 py-2 text-sm font-medium text-background opacity-0 shadow-lg transition"
  >
    Copied import
  </div>
</BaseLayout>

<script>
  function initIconGallery() {
    const search = document.getElementById("icon-search") as HTMLInputElement | null;
    const grid = document.getElementById("icon-grid");
    const count = document.getElementById("icon-count");
    const empty = document.getElementById("icon-empty");
    const toast = document.getElementById("copy-toast");
    if (!search || !grid) return;

    const items = Array.from(grid.querySelectorAll<HTMLElement>("[data-icon]"));
    const total = items.length;

    function filter() {
      const q = search!.value.trim().toLowerCase();
      const terms = q.split(/\s+/).filter(Boolean);
      let shown = 0;
      for (const el of items) {
        const kw = el.dataset.name || "";
        // Every typed term must appear somewhere in the icon's keywords.
        const match = terms.length === 0 || terms.every((t) => kw.includes(t));
        el.classList.toggle("hidden", !match);
        if (match) shown++;
      }
      if (count) count.textContent = q ? `${shown} of ${total} icons` : `${total} icons`;
      if (empty) empty.classList.toggle("hidden", shown !== 0);
    }
    search.addEventListener("input", filter);

    let toastTimer: ReturnType<typeof setTimeout>;
    grid.addEventListener("click", async (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLButtonElement>("[data-copy]");
      if (!btn) return;
      try {
        await navigator.clipboard.writeText(btn.dataset.copy || "");
        if (toast) {
          toast.style.opacity = "1";
          toast.style.transform = "translate(-50%, 0)";
          clearTimeout(toastTimer);
          toastTimer = setTimeout(() => {
            toast.style.opacity = "0";
            toast.style.transform = "translate(-50%, 8px)";
          }, 1400);
        }
      } catch {}
    });
  }

  initIconGallery();
  document.addEventListener("astro:after-swap", initIconGallery);
</script>
