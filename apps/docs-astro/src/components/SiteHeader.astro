---
import ThemeToggle from "@/components/ThemeToggle.astro";
import logoWithTextLight from "@/assets/brand/logo-with-text-light.webp?url";
import logoWithTextDark from "@/assets/brand/logo-with-text-dark.webp?url";

// Hardcoded for now — swap for a real GitHub stars fetch later.
const githubStars = "1.4K";
const githubUrl = "https://github.com/yersonv10/lumina";
---

<header class="sticky top-0 z-40 border-b border-border bg-background/90 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-3">
    <a href="/" class="flex items-center">
      <img src={logoWithTextLight} height="24" alt="Lumina" class="h-6 w-auto dark:hidden" />
      <img src={logoWithTextDark} height="24" alt="Lumina" class="hidden h-6 w-auto dark:block" />
    </a>
    <nav class="hidden items-center gap-6 text-sm text-text-secondary md:flex">
      <a href="/installation" class="hover:text-text-primary">Installation</a>
      <a href="/get-started/quick-start" class="hover:text-text-primary">Docs</a>
      <a href="/components" class="hover:text-text-primary">Components</a>
      <a href="/icons" class="hover:text-text-primary">Icons</a>
    </nav>
    <div class="flex items-center gap-2">
      <a
        href={githubUrl}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`Lumina on GitHub — ${githubStars} stars`}
        class="inline-flex items-center gap-2 rounded-(--radius-control) border border-border px-2.5 py-1.5 text-sm text-text-secondary transition hover:bg-background-soft hover:text-text-primary"
      >
        <svg class="size-4 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
          />
        </svg>
        <span class="flex items-center gap-1 font-medium tabular-nums">
          <svg class="size-3.5 text-primary-500" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path
              d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"
            />
          </svg>
          {githubStars}
        </span>
      </a>
      <ThemeToggle />
    </div>
  </div>
</header>
