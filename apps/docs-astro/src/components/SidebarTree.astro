---
import type { SidebarNode } from "@/lib/sidebar";
import SidebarTree from "@/components/SidebarTree.astro";

interface Props {
  nodes: SidebarNode[];
  currentPath: string;
}

const { nodes, currentPath } = Astro.props;
---

<ul class="space-y-1">
  {
    nodes.map((node) => {
      if (node.type === "link") {
        return (
          <li>
            <a
              href={node.href}
              target={node.external ? "_blank" : undefined}
              rel={node.external ? "noreferrer" : undefined}
              class="block rounded-(--radius-control) px-2 py-1.5 text-sm text-text-secondary hover:bg-background-soft hover:text-text-primary"
            >
              {node.label}
            </a>
          </li>
        );
      }

      if (node.type === "page") {
        const active = currentPath === node.href;
        return (
          <li>
            <a
              href={node.href}
              class:list={[
                "flex items-center justify-between rounded-(--radius-control) px-2 py-1.5 text-sm",
                active
                  ? "bg-primary-500/10 font-medium text-primary-500"
                  : "text-text-secondary hover:bg-background-soft hover:text-text-primary",
              ]}
            >
              <span>{node.label}</span>
              {node.badge && (
                <span class="rounded-full bg-primary-500/15 px-1.5 py-0.5 font-mono text-[10px] text-primary-500 uppercase">
                  {node.badge}
                </span>
              )}
            </a>
          </li>
        );
      }

      return (
        <li>
          <details open={node.defaultOpen}>
            <summary class="cursor-pointer rounded-(--radius-control) px-2 py-1.5 text-sm font-medium text-text-primary marker:content-none">
              {node.label}
            </summary>
            <div class="mt-1 ml-3 border-l border-border pl-3">
              <SidebarTree nodes={node.children} currentPath={currentPath} />
            </div>
          </details>
        </li>
      );
    })
  }
</ul>
