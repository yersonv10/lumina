---
interface Ide {
  name: string;
  icon: string | { light: string; dark: string };
  href: string;
}

const ides: Ide[] = [
  { name: "VS Code", icon: "vscode.svg", href: "vscode:extension/lumina.lumina-mcp" },
  {
    name: "Cursor",
    icon: { light: "cursor-light.svg", dark: "cursor-dark.svg" },
    href: "cursor:extension/lumina.lumina-mcp",
  },
  { name: "Antigravity", icon: "antigravity.svg", href: "antigravity:extension/lumina.lumina-mcp" },
  {
    name: "Windsurf",
    icon: { light: "windsurf-light.svg", dark: "windsurf-dark.svg" },
    href: "windsurf:extension/lumina.lumina-mcp",
  },
];
---

<div class="not-prose my-6 grid grid-cols-1 gap-2.5 sm:grid-cols-2 md:grid-cols-3">
  {
    ides.map((ide) => (
      <a
        href={ide.href}
        class="flex flex-col items-center gap-3 rounded-(--radius-card) border border-border bg-background-raised p-10 no-underline transition hover:bg-background-soft"
      >
        {typeof ide.icon === "object" ? (
          <>
            <img src={`/images/logos/${ide.icon.light}`} alt={ide.name} width="40" height="40" class="size-10 dark:hidden" />
            <img src={`/images/logos/${ide.icon.dark}`} alt={ide.name} width="40" height="40" class="hidden size-10 dark:block" />
          </>
        ) : (
          <img src={`/images/logos/${ide.icon}`} alt={ide.name} width="40" height="40" class="size-10" />
        )}
        <p class="text-text-primary text-nowrap">{ide.name}</p>
      </a>
    ))
  }
</div>
