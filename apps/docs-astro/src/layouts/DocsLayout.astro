---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import SidebarTree from "@/components/SidebarTree.astro";
import { buildSidebar, flattenPages } from "@/lib/sidebar";

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description?: string;
  headings?: Heading[];
}

const { title, description, headings = [] } = Astro.props;
const currentPath = "/" + Astro.params.slug;

const tree = await buildSidebar();
const pages = flattenPages(tree);
const index = pages.findIndex((p) => p.href === currentPath);
const prev = index > 0 ? pages[index - 1] : undefined;
const next = index >= 0 && index < pages.length - 1 ? pages[index + 1] : undefined;

const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

<BaseLayout title={title} description={description}>
  <SiteHeader />
  <div class="mx-auto flex max-w-7xl gap-8 px-6 py-8">
    <aside class="hidden w-64 shrink-0 lg:block">
      <nav class="sticky top-20">
        <SidebarTree nodes={tree} currentPath={currentPath} />
      </nav>
    </aside>

    <main class="min-w-0 flex-1 py-2">
      <article class="prose prose-neutral dark:prose-invert max-w-3xl">
        <slot />
      </article>

      <nav class="mt-12 flex max-w-3xl justify-between border-t border-border pt-6 text-sm">
        {
          prev ? (
            <a href={prev.href} class="text-text-secondary hover:text-text-primary">
              ← {prev.label}
            </a>
          ) : (
            <span />
          )
        }
        {
          next ? (
            <a href={next.href} class="text-text-secondary hover:text-text-primary">
              {next.label} →
            </a>
          ) : (
            <span />
          )
        }
      </nav>
    </main>

    {
      toc.length > 0 && (
        <aside class="hidden w-56 shrink-0 xl:block">
          <nav class="sticky top-20 text-sm">
            <p class="font-mono text-xs tracking-widest text-text-muted uppercase">On this page</p>
            <ul class="mt-3 space-y-2">
              {toc.map((h) => (
                <li class:list={["ml-0", h.depth === 3 && "ml-3"]}>
                  <a href={`#${h.slug}`} class="text-text-secondary hover:text-text-primary">
                    {h.text}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </aside>
      )
    }
  </div>
</BaseLayout>
